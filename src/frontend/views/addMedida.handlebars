<div id="container-medidas">
    <h1>Cadastro de Medidas</h1>
    <div id="container-form">
        <form id="form" action="/clientes/medidas/{{clienteId}}/" method="post">
            <label>Busto:</label>
            <br>
            <input type="text" name="busto">
            <br><br>

            <label>Cintura:</label>
            <br>
            <input type="text" name="cintura">
            <br><br>

            <label>Quadril:</label>
            <br>
            <input type="text" name="quadril">
            <br><br>

            <label>Comprimento</label>
            <br>
            <input type="text" name="comprimento">
            <br><br>

            <label>Ombro:</label>
            <br>
            <input type="text" name="ombro">
            <br><br>

            <label>Costas:</label>
            <br>
            <input type="text" name="costas">
            <br><br>

            <label>Comprimento da Manga:</label>
            <br>
            <input type="text" name="comprimento_da_manga">
            <br><br>

            <label>Largura da Manga</label>
            <br>
            <input type="text" name="largura_da_manga">
            <br><br>

            <button type="submit">Enviar</button>
        </form>
    </div>
</div>
    
