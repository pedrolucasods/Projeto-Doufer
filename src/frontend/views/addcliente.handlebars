{{#if msg}}
<div id="msg" class="d-flex gap-3 alert alert-success alert-dismissible fade show position-fixed top-0 end-0 me-5 m-3">
    <i class="bi bi-check-square-fill text-success"></i>
    <p class="fw-bold mb-0">{{msg}}</p>
</div>
{{/if}}
{{#if error}}
<div id="errordiv" class="d-flex gap-3 alert alert-danger alert-dismissible fade show position-fixed top-0 end-0 me-5 m-3">
    <i class="bi bi-x-square-fill text-danger"></i>
    <p class="fw-bold mb-0">{{error}}</p>
</div>
{{/if}}
<div>
    <h1>Cadastro Cliente</h1>
    <div>
        <form id="formaddcliente" method="post">
            <p>Tipo do cliente</p>
            <select name="tipo_cliente" id="tipo_cliente">
                <option value="">Selecione o tipo</option>
                <option value="pessoa">Pessoa</option>
                <option value="empresa">Empresa</option>
            </select>
            <span id="spanTipo_cliente"></span>
            <p>Nome: </p>
            <input id="inputnome" type="text" name="namecliente" required>
            <span id="spanname"></span>

            <p id="pnomeempresa">Deseja Nome da Empresa?</p>
            <input type="checkbox" id="toggleempresa" name="inserirempresa">

            <div id="empresaContainer" style="display: none;">
                <p>Nome da empresa:</p>
                <input type="text" name="empresacliente" id="empresaInput">
            </div>

            <p>Telefone: </p>
            <input id="telefone" name="telefonecliente" required placeholder="(00) 00000-0000..."></input>
            <span id="spanphone"></span>

            <p>
                Deseja inserir CPF?
                <input type="checkbox" id="toggleCpf" name="inserirCpf">
            </p>

            <div id="cpfContainer" style="display: none;">
                <p>CPF:</p>
                <input type="text" name="cpfcliente" id="cpfInput" placeholder="000.000.000-00">
            </div>
            <br>
            <button type="submit">Cadastrar cliente</button>
         </form>
    </div>
</div>
 